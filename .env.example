# Port configuration
PORT=8000
STREAMLIT_PORT=8501

# API Keys
# Add your Gemini API Key if you want to use the Gemini provider
GEMINI_API_KEY=

# Hugging Face Inference API Token (optional, for higher rate limits)
HF_API_TOKEN=

# AI Provider selection: 'huggingface', 'gemini', 'local', or 'fallback'
AI_PROVIDER=fallback
